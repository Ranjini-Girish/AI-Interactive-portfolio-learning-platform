# Copy to .env.local for local dev; add same keys in Vercel Project Settings → Environment Variables

# Optional — live AI mentor in Build Lab + Interview Copilot (server-side suggestions)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — premium audio tutor voice (falls back to browser TTS)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Optional — contact form email delivery (https://resend.com)
RESEND_API_KEY=
CONTACT_TO_EMAIL=Racgowda18@gmail.com
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# Hugging Face Inference Providers — required for real summarization + RAG embeddings
# Get token: https://huggingface.co/settings/tokens → Fine-grained → "Make calls to Inference Providers"
# Quick setup: run SETUP-LAB-ENV.bat or scripts/setup-lab-env.ps1
# Verify: http://localhost:3200/lab/setup
HF_TOKEN=
HF_SUMMARY_MODEL=facebook/bart-large-cnn
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Supabase — lab proof links (run supabase/schema.sql in SQL Editor)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=

# Canonical site URL (proof links, OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3200

# Public demo URLs after you deploy P01/P02 (shown on portfolio page)
NEXT_PUBLIC_DEMO_P01_URL=http://localhost:5173
NEXT_PUBLIC_DEMO_P02_URL=http://localhost:5174
NEXT_PUBLIC_DEMO_P03_URL=http://localhost:5175
