# Copy to .env and fill in your Snorkel Experts credentials.
SNORKEL_EMAIL=you@example.com
SNORKEL_PASSWORD=your-password-here
SNORKEL_BASE_URL=https://experts.snorkel-ai.com

# New task submission (use one of these)
# SNORKEL_TASK_DIR=tasks/export-batch-window-audit
# SNORKEL_TASK_ZIP=C:\path\to\my-task.zip

# submit:new:live — cycle-1 platform submit
# SNORKEL_SUBMIT=1
# SNORKEL_STATIC_CHECKS=1
# SNORKEL_REGENERATE_RUBRIC=1

# submit:new (dry) — upload form only, no Submit click
# SNORKEL_DRY_RUN=1

# After live submit, writes tasks/<name>/platform-submission.json (on by default).
# SNORKEL_SAVE_METADATA=0      # disable; =1 also saves dry-run rehearsals
# SNORKEL_E2E_REPO_ROOT=..     # override repo root (tests only)

# Revision flow
# SNORKEL_REVISION_TASK_ID=65a57882-098e-4157-b242-ae5ce58e818a
# SNORKEL_SEND_TO_REVIEWER=0   # optional: uncheck Send to reviewer (default is checked)
