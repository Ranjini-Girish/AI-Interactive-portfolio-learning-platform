{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "summary.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "endpoints_at_end",
    "events_with_diagnostics",
    "global_tick_at_end",
    "peak_open_endpoints",
    "total_admitted",
    "total_events",
    "total_failures",
    "total_requests",
    "total_short_circuited",
    "total_state_transitions",
    "total_successes",
    "total_timeouts",
    "total_transitions_to_closed",
    "total_transitions_to_half_open",
    "total_transitions_to_open"
  ],
  "properties": {
    "endpoints_at_end":               { "type": "integer", "minimum": 0 },
    "events_with_diagnostics":        { "type": "integer", "minimum": 0 },
    "global_tick_at_end":             { "type": "integer", "minimum": 0 },
    "peak_open_endpoints":            { "type": "integer", "minimum": 0 },
    "total_admitted":                 { "type": "integer", "minimum": 0 },
    "total_events":                   { "type": "integer", "minimum": 0 },
    "total_failures":                 { "type": "integer", "minimum": 0 },
    "total_requests":                 { "type": "integer", "minimum": 0 },
    "total_short_circuited":          { "type": "integer", "minimum": 0 },
    "total_state_transitions":        { "type": "integer", "minimum": 0 },
    "total_successes":                { "type": "integer", "minimum": 0 },
    "total_timeouts":                 { "type": "integer", "minimum": 0 },
    "total_transitions_to_closed":    { "type": "integer", "minimum": 0 },
    "total_transitions_to_half_open": { "type": "integer", "minimum": 0 },
    "total_transitions_to_open":      { "type": "integer", "minimum": 0 }
  }
}
