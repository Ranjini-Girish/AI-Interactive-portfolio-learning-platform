{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "final_endpoints.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["endpoints"],
  "properties": {
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "current_failure_threshold_pct",
          "current_half_open_max_probes",
          "current_recovery_ticks",
          "current_window_size",
          "id",
          "last_state_change_seq",
          "probe_failures",
          "probe_successes",
          "probes_used",
          "state",
          "state_transition_count",
          "tick_entered_open",
          "total_admitted",
          "total_failures",
          "total_short_circuited",
          "total_successes",
          "total_timeouts"
        ],
        "properties": {
          "current_failure_threshold_pct": {
            "type": "integer", "minimum": 1, "maximum": 100
          },
          "current_half_open_max_probes": { "type": "integer", "minimum": 1 },
          "current_recovery_ticks":        { "type": "integer", "minimum": 0 },
          "current_window_size":           { "type": "integer", "minimum": 1 },
          "id":                            { "type": "string" },
          "last_state_change_seq":         { "type": ["integer", "null"] },
          "probe_failures":                { "type": "integer", "minimum": 0 },
          "probe_successes":               { "type": "integer", "minimum": 0 },
          "probes_used":                   { "type": "integer", "minimum": 0 },
          "state": {
            "type": "string",
            "enum": ["CLOSED", "OPEN", "HALF_OPEN"]
          },
          "state_transition_count":        { "type": "integer", "minimum": 0 },
          "tick_entered_open":             { "type": ["integer", "null"] },
          "total_admitted":                { "type": "integer", "minimum": 0 },
          "total_failures":                { "type": "integer", "minimum": 0 },
          "total_short_circuited":         { "type": "integer", "minimum": 0 },
          "total_successes":               { "type": "integer", "minimum": 0 },
          "total_timeouts":                { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
