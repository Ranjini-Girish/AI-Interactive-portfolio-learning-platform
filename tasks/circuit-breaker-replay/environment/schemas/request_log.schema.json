{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "request_log.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["requests"],
  "properties": {
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "admission",
          "endpoint_id",
          "outcome",
          "seq",
          "state_at_admission"
        ],
        "properties": {
          "admission": {
            "type": "string",
            "enum": ["admitted", "probe_admitted", "short_circuited"]
          },
          "endpoint_id": { "type": "string" },
          "outcome": {
            "type": "string",
            "enum": ["success", "failure", "timeout"]
          },
          "seq": { "type": "integer", "minimum": 0 },
          "state_at_admission": {
            "type": "string",
            "enum": ["CLOSED", "OPEN", "HALF_OPEN"]
          }
        }
      }
    }
  }
}
