{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "implicit_init_harvest": {
      "type": "boolean"
    },
    "init_pid": {
      "minimum": 1,
      "type": "integer"
    },
    "orphan_handling": {
      "enum": [
        "reparent_to_init",
        "leave_orphaned"
      ]
    },
    "track_lineage": {
      "type": "boolean"
    },
    "wait_on_living_child": {
      "enum": [
        "diagnostic",
        "noop"
      ]
    }
  },
  "required": [
    "init_pid",
    "orphan_handling",
    "implicit_init_harvest",
    "wait_on_living_child",
    "track_lineage"
  ],
  "title": "policy.json",
  "type": "object"
}
