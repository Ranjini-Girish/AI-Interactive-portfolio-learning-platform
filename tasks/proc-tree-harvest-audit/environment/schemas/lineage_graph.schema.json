{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cycles": {
      "items": {
        "items": {
          "minimum": 1,
          "type": "integer"
        },
        "type": "array"
      },
      "type": "array"
    },
    "edges": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "from": {
            "minimum": 1,
            "type": "integer"
          },
          "to": {
            "minimum": 1,
            "type": "integer"
          },
          "type": {
            "enum": [
              "fork",
              "reparent_init"
            ]
          }
        },
        "required": [
          "from",
          "to",
          "type"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "nodes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "id": {
            "minimum": 1,
            "type": "integer"
          },
          "in_degree": {
            "minimum": 0,
            "type": "integer"
          },
          "out_degree": {
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "id",
          "in_degree",
          "out_degree"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "cycles",
    "edges",
    "nodes"
  ],
  "title": "lineage_graph.json",
  "type": "object"
}
