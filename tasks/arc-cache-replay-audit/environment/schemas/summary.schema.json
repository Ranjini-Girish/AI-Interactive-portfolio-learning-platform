{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "summary.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accesses_accepted",
    "clears_accepted",
    "clears_rejected",
    "evicts_accepted",
    "evicts_rejected",
    "final_b1_weight_sum",
    "final_b2_weight_sum",
    "final_p",
    "final_t1_weight_sum",
    "final_t2_weight_sum",
    "ghost_hits_b1",
    "ghost_hits_b2",
    "hits_t1",
    "hits_t2",
    "misses",
    "total_accesses",
    "total_clears",
    "total_distinct_keys",
    "total_events",
    "total_evicts",
    "total_weight_admitted"
  ],
  "properties": {
    "accesses_accepted": {"type": "integer", "minimum": 0},
    "clears_accepted": {"type": "integer", "minimum": 0},
    "clears_rejected": {"type": "integer", "minimum": 0},
    "evicts_accepted": {"type": "integer", "minimum": 0},
    "evicts_rejected": {"type": "integer", "minimum": 0},
    "final_b1_weight_sum": {"type": "integer", "minimum": 0},
    "final_b2_weight_sum": {"type": "integer", "minimum": 0},
    "final_p": {"type": "integer", "minimum": 0, "maximum": 256},
    "final_t1_weight_sum": {"type": "integer", "minimum": 0},
    "final_t2_weight_sum": {"type": "integer", "minimum": 0},
    "ghost_hits_b1": {"type": "integer", "minimum": 0},
    "ghost_hits_b2": {"type": "integer", "minimum": 0},
    "hits_t1": {"type": "integer", "minimum": 0},
    "hits_t2": {"type": "integer", "minimum": 0},
    "misses": {"type": "integer", "minimum": 0},
    "total_accesses": {"type": "integer", "minimum": 0},
    "total_clears": {"type": "integer", "minimum": 0},
    "total_distinct_keys": {"type": "integer", "minimum": 0},
    "total_events": {"type": "integer", "minimum": 0},
    "total_evicts": {"type": "integer", "minimum": 0},
    "total_weight_admitted": {"type": "integer", "minimum": 0}
  }
}
