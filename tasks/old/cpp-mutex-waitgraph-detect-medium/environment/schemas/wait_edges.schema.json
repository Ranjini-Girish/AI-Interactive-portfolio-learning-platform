{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["edges"],
  "properties": {
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mutex", "owner", "waiter"],
        "properties": {
          "mutex": { "type": "string" },
          "owner": { "type": "string" },
          "waiter": { "type": "string" }
        }
      }
    }
  }
}
