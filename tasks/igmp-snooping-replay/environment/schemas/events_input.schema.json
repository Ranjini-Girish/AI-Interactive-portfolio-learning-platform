{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events_input.schema.json",
  "title": "events.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["group", "op", "port", "seq", "vlan"],
            "properties": {
              "op": { "const": "igmp_report" },
              "seq": { "type": "integer", "minimum": 0 },
              "port": { "type": "string", "minLength": 1 },
              "group": { "type": "string", "pattern": "^(2(2[4-9]|3[0-9])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]))$" },
              "vlan": { "type": "integer", "minimum": 1, "maximum": 4094 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["group", "op", "port", "seq", "vlan"],
            "properties": {
              "op": { "const": "igmp_leave" },
              "seq": { "type": "integer", "minimum": 0 },
              "port": { "type": "string", "minLength": 1 },
              "group": { "type": "string", "pattern": "^(2(2[4-9]|3[0-9])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]))$" },
              "vlan": { "type": "integer", "minimum": 1, "maximum": 4094 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["group", "ingress_port", "len", "op", "seq", "vlan"],
            "properties": {
              "op": { "const": "mcast_frame" },
              "seq": { "type": "integer", "minimum": 0 },
              "ingress_port": { "type": "string", "minLength": 1 },
              "group": { "type": "string", "pattern": "^(2(2[4-9]|3[0-9])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]))$" },
              "vlan": { "type": "integer", "minimum": 1, "maximum": 4094 },
              "len": { "type": "integer", "minimum": 64, "maximum": 9216 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["op", "port", "seq", "up"],
            "properties": {
              "op": { "const": "port_link_change" },
              "seq": { "type": "integer", "minimum": 0 },
              "port": { "type": "string", "minLength": 1 },
              "up": { "type": "boolean" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["delta_sec", "op", "seq"],
            "properties": {
              "op": { "const": "tick" },
              "seq": { "type": "integer", "minimum": 0 },
              "delta_sec": { "type": "integer", "minimum": 1 }
            }
          }
        ]
      }
    }
  }
}
