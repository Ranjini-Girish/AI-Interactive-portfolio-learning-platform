{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "igmp_diagnostics.schema.json",
  "title": "igmp_diagnostics.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["diagnostics"],
  "properties": {
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "name", "seq", "severity"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "severity": { "type": "string", "enum": ["error", "warning", "note"] },
          "code": {
            "type": "string",
            "enum": [
              "E_INGRESS_PORT_DOWN",
              "E_INGRESS_VLAN_MISMATCH",
              "E_LEAVE_UNKNOWN_GROUP",
              "W_REPORT_REFRESH",
              "W_FAST_LEAVE",
              "W_LINK_NOOP",
              "W_LINK_DOWN_PURGE",
              "W_MEMBER_AGED",
              "W_DROPPED_NO_MEMBERS"
            ]
          },
          "name": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
