{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mcast_table.schema.json",
  "title": "mcast_table.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["groups"],
  "properties": {
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["group", "members", "vlan"],
        "properties": {
          "group": { "type": "string", "pattern": "^(2(2[4-9]|3[0-9])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]))$" },
          "vlan": { "type": "integer", "minimum": 1, "maximum": 4094 },
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["last_seen_time", "port"],
              "properties": {
                "last_seen_time": { "type": "integer", "minimum": 0 },
                "port": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
