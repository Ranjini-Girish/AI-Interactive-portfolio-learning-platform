{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mutex", "op", "seq", "task", "tick"],
        "properties": {
          "mutex": { "type": ["string", "null"] },
          "op": {
            "type": "string",
            "enum": ["tick", "acquire", "release", "try_acquire"]
          },
          "seq": { "type": "integer", "minimum": 0 },
          "task": { "type": ["string", "null"] },
          "tick": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
