{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["diagnostics", "seq"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "diagnostics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "mutex", "severity"],
              "properties": {
                "code": { "type": "string" },
                "mutex": { "type": ["string", "null"] },
                "severity": {
                  "type": "string",
                  "enum": ["error", "warning", "note"]
                }
              }
            }
          }
        }
      }
    }
  }
}
