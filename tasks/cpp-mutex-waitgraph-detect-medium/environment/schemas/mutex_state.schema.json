{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["mutexes"],
  "properties": {
    "mutexes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "owner"],
        "properties": {
          "name": { "type": "string" },
          "owner": { "type": ["string", "null"] }
        }
      }
    }
  }
}
