{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "delivery_log.json",
  "type": "object",
  "required": ["deliveries"],
  "additionalProperties": false,
  "properties": {
    "deliveries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["payload_id", "publish_qos", "recipients", "seq", "topic"],
        "additionalProperties": false,
        "properties": {
          "payload_id":  {"type": "integer", "minimum": 0},
          "publish_qos": {"type": "integer", "minimum": 0, "maximum": 2},
          "recipients": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["client_id", "delivered_qos"],
              "additionalProperties": false,
              "properties": {
                "client_id":     {"type": "string"},
                "delivered_qos": {"type": "integer", "minimum": 0, "maximum": 2}
              }
            }
          },
          "seq":   {"type": "integer", "minimum": 0},
          "topic": {"type": "string"}
        }
      }
    }
  }
}
