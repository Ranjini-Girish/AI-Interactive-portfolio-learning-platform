{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "policy_summary.schema.json",
  "title": "Policy summary output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "default_action_uses",
    "effective",
    "escalation_warnings",
    "redundant",
    "shadowed",
    "total_rules",
    "unreachable"
  ],
  "properties": {
    "default_action_uses": {"type": "integer", "minimum": 0},
    "effective": {"type": "integer", "minimum": 0},
    "redundant": {"type": "integer", "minimum": 0},
    "shadowed": {"type": "integer", "minimum": 0},
    "total_rules": {"type": "integer", "minimum": 0},
    "unreachable": {"type": "integer", "minimum": 0},
    "escalation_warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["earlier_rule_id", "rule_id", "type"],
        "properties": {
          "earlier_rule_id": {"type": "string", "minLength": 1},
          "rule_id": {"type": "string", "minLength": 1},
          "type": {"type": "string", "enum": ["deny_after_allow"]}
        }
      }
    }
  }
}
