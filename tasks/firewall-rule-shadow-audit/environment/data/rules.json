      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 9090, "end": 9090}],
      "description": "Dev subnet to single DMZ host metrics port - effective only because r23-25 are TCP-port-1-65535 but exclude 9090? Actually 9090 IS in [1,65535]; this is shadowed by r23 if r23 wins by priority"
    },
    {
      "id": "r27",
      "priority": 45,
      "action": "allow",
      "direction": "ingress",
      "source": "10.0.20.0/24",
