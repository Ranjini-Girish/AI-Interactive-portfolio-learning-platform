    },
    {
      "id": "r28",
      "priority": 55,
      "action": "deny",
      "direction": "ingress",
      "source": "10.0.20.0/24",
      "destination": "10.0.30.10/32",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 6379, "end": 6379}],
      "description": "Conflicting deny for same redis flow - removing r27 promotes/changes verdict path through r28"
    },
    {
      "id": "r29",
      "priority": 33,
      "action": "allow",
      "direction": "ingress",
      "source": "10.0.40.0/27",
      "destination": "10.0.10.5/32",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 443, "end": 443}],
      "description": "Earliest dev->DMZ HTTPS allow - higher priority than r23-25, makes r25 effectively unreachable for the /27 prefix only when r29 present"
    },
    {
      "id": "r30",
      "priority": 26,
      "action": "allow",
      "direction": "ingress",
      "source": "10.0.20.0/24",
      "destination": "10.0.10.5/32",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 8443, "end": 8443}],
      "description": "Exact predicate duplicate of r22 with priority 26 (lower-priority loses) - r22 wins, r30 is shadowed; removing r22 promotes r30"
    },
    {
      "id": "r31",
      "priority": -10,
      "action": "allow",
      "direction": "ingress",
      "source": "10.0.60.0/24",
      "destination": "10.0.10.0/24",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 443, "end": 443}],
      "description": "NEGATIVE priority -10: under priority_lowest_wins this rule must evaluate strictly before every priority>=0 rule. Trap for agents that sort priorities as unsigned or absolute-value."
    },
    {
      "id": "r32",
      "priority": 15,
      "action": "deny",
      "direction": "ingress",
      "source": "10.0.70.0/24",
      "destination": "10.0.10.20/32",
      "protocol": "udp",
      "src_ports": "any",
      "dst_ports": [{"start": 5353, "end": 5353}],
      "description": "Deny udp/5353 from 10.0.70.0/24 to a specific DMZ host. Removing r32 lets the matching flow fall through to r20 (ingress catch-all deny). Both verdicts are 'deny' so removing r32 leaves every flow's allow/deny outcome unchanged - r32 must be classified 'redundant'. Trap for agents that compare matched_rule_id pair (which DOES change) instead of normalized verdict."
    },
    {
      "id": "r33",
      "priority": 10,
      "action": "deny",
      "direction": "ingress",
      "source": "10.0.80.0/24",
      "destination": "10.0.10.0/24",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 443, "end": 443}],
      "description": "Same priority 10 as r01/r02. Predicate overlaps r01 on 10.0.80.0/24->10.0.10.0/24 HTTPS flows. Under priority_lowest_wins, ASCII id tie-break: r01<r02<r33, so r01 still wins where predicates overlap. r33 is the head of an HTTPS-deny chain that competes against r01. Trap for agents that pick first-encountered or sort by source CIDR."
    },
    {
      "id": "r34",
      "priority": 8,
      "action": "deny",
      "direction": "ingress",
      "source": "10.0.81.0/24",
      "destination": "10.0.10.20/32",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 22, "end": 22}],
      "description": "Lowest priority 8 wins via priority_lowest_wins. Sole rule for 10.0.81.0/24 SSH-to-DMZ. Removing r34 sends matching flow to default (== allow). verdict_change must be {from: 'deny', to: 'allow'} (NORMALIZED, not 'default'). Trap for agents that emit raw 'default' string in verdict_changes.to_verdict."
    },
    {
      "id": "r35",
      "priority": 150,
      "action": "deny",
      "direction": "ingress",
      "source": "any",
      "destination": "10.0.10.0/24",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 7000, "end": 6500}],
      "description": "UNREACHABLE deny (inverted port range -> unsatisfiable). Predicate would (if satisfiable) overlap r01/r02/r19 which are earlier allows. Per spec, escalation_warnings must EXCLUDE pairs where the deny is unreachable or redundant. Trap for agents that emit deny_after_allow regardless of deny status."
    },
    {
      "id": "r36",
      "priority": 32,
      "action": "allow",
      "direction": "ingress",
      "source": "10.0.20.30/32",
      "destination": "10.0.10.0/24",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 22, "end": 22}],
      "description": "Specific-host SSH allow to DMZ. Wins over r05 (priority 30 vs r36 priority 32 - WAIT under priority_lowest_wins lower wins so r05 still wins). Therefore r36 is shadowed by r05 in baseline. Removing r05 PROMOTES r36 to effective. Use as promotion-graph node."
    },
    {
      "id": "r37",
      "priority": 22,
      "action": "allow",
      "direction": "ingress",
      "source": "10.0.20.7/32",
      "destination": "10.0.30.10/32",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 3306, "end": 3306}],
      "description": "Specific 10.0.20.7 host to DB MySQL. Same predicate covered by r10 (priority 70) but r37 has priority 22 < 70, so r37 wins under priority_lowest_wins for this exact flow. Removing r37 keeps verdict 'allow' but changes matched_rule_id to r10 -> appears in flows_changed but NOT in verdict_changes. Trap for agents that conflate matched_rule_id with verdict."
    },
    {
      "id": "r38",
      "priority": 95,
      "action": "deny",
      "direction": "ingress",
      "source": "10.0.20.30/32",
      "destination": "10.0.10.20/32",
      "protocol": "tcp",
      "src_ports": "any",
      "dst_ports": [{"start": 9090, "end": 9090}],
      "description": "Single host SSH ban to a specific DMZ host. Used only for predicate-only matched_flows: matches one flow but baseline status depends on what comes earlier."
    }
  ]
