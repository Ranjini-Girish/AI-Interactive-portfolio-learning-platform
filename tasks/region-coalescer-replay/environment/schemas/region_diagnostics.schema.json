{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "region_diagnostics.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["diagnostics", "seq"],
        "properties": {
          "seq": { "type": "integer", "minimum": 0 },
          "diagnostics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "region_id", "severity"],
              "properties": {
                "code": {
                  "type": "string",
                  "enum": [
                    "E_REGION_NOT_FOUND",
                    "E_DUPLICATE_ID",
                    "E_OVERLAP_REJECTED",
                    "E_BELOW_MIN_SIZE",
                    "E_SPLIT_OUT_OF_RANGE",
                    "E_MERGE_NOT_ADJACENT",
                    "W_REPLACED_OVERLAP",
                    "N_AUTO_COALESCED"
                  ]
                },
                "region_id": { "type": ["string", "null"] },
                "severity":  { "type": "string", "enum": ["error", "warning", "note"] }
              }
            }
          }
        }
      }
    }
  }
}
