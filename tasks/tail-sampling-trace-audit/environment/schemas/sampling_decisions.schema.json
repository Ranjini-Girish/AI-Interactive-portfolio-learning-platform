{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "sampling_decisions.json",
  "type": "object",
  "required": ["decisions"],
  "additionalProperties": false,
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "matched_policy", "reason", "trace_id"],
        "additionalProperties": false,
        "properties": {
          "decision":       { "type": "string", "enum": ["keep", "drop"] },
          "matched_policy": { "type": ["string", "null"] },
          "reason": {
            "type": "string",
            "enum": [
              "cycle_detected", "multi_root", "incomplete_trace",
              "orphan_span", "policy_match", "no_policy_matched"
            ]
          },
          "trace_id":       { "type": "string", "pattern": "^[0-9a-f]{16}$" }
        }
      }
    }
  }
}
