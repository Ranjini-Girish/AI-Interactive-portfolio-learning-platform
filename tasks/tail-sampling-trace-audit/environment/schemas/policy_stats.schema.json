{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "policy_stats.json",
  "type": "object",
  "required": ["policies"],
  "additionalProperties": false,
  "properties": {
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dropped_count", "kept_count", "matched_count", "name", "type"],
        "additionalProperties": false,
        "properties": {
          "dropped_count": { "type": "integer", "minimum": 0 },
          "kept_count":    { "type": "integer", "minimum": 0 },
          "matched_count": { "type": "integer", "minimum": 0 },
          "name":          { "type": "string" },
          "type":          { "type": "string", "enum": ["status_match", "latency", "attribute", "service", "probabilistic"] }
        }
      }
    }
  }
}
