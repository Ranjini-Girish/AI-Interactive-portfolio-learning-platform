{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "buckets.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["buckets"],
  "properties": {
    "buckets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bucket_id", "capacity_bytes", "leak_bytes_per_tick"],
        "properties": {
          "bucket_id": {
            "type": "string", "minLength": 1, "maxLength": 32,
            "pattern": "^[A-Za-z0-9._-]+$"
          },
          "capacity_bytes": { "type": "integer", "minimum": 1, "maximum": 1000000000 },
          "leak_bytes_per_tick": { "type": "integer", "minimum": 0, "maximum": 1000000000 }
        }
      }
    }
  }
}
