{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "processes.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["processes"],
  "properties": {
    "processes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pid", "ppid", "uid", "state", "start_tick", "cmdline"],
        "properties": {
          "pid": {"type": "integer", "minimum": 1},
          "ppid": {"type": "integer", "minimum": 0},
          "uid": {"type": "integer", "minimum": 0},
          "state": {"const": "RUNNING"},
          "start_tick": {"type": "integer", "minimum": 0},
          "cmdline": {"type": "string"}
        }
      }
    }
  }
}
