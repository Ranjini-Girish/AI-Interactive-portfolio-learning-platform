{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "process_diagnostics.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["diagnostics", "seq"],
        "properties": {
          "seq": {"type": "integer", "minimum": 0},
          "diagnostics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "pid", "severity"],
              "properties": {
                "code": {
                  "enum": [
                    "E_INVALID_PARENT",
                    "E_PID_REUSED",
                    "E_INVALID_TARGET",
                    "E_DOUBLE_EXIT",
                    "E_NOT_CHILD",
                    "E_NOT_ZOMBIE",
                    "W_KILLED_BY_SIGNAL",
                    "W_ORPHANED",
                    "W_ZOMBIE_LEAK",
                    "N_AUTO_REAPED",
                    "N_REAPED"
                  ]
                },
                "pid": {
                  "anyOf": [
                    {"type": "integer", "minimum": 1},
                    {"type": "null"}
                  ]
                },
                "severity": {"enum": ["error", "warning", "note"]}
              }
            }
          }
        }
      }
    }
  }
}
