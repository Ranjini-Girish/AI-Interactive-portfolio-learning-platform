{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "summary.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "auto_reaped",
    "events_with_diagnostics",
    "explicit_reaped",
    "final_alive_count",
    "forks_rejected",
    "forks_succeeded",
    "killed_by_signal",
    "max_concurrent_processes",
    "orphans_reparented",
    "total_events",
    "users_at_end",
    "zombies_at_end"
  ],
  "properties": {
    "auto_reaped": {"type": "integer", "minimum": 0},
    "events_with_diagnostics": {"type": "integer", "minimum": 0},
    "explicit_reaped": {"type": "integer", "minimum": 0},
    "final_alive_count": {"type": "integer", "minimum": 0},
    "forks_rejected": {"type": "integer", "minimum": 0},
    "forks_succeeded": {"type": "integer", "minimum": 0},
    "killed_by_signal": {"type": "integer", "minimum": 0},
    "max_concurrent_processes": {"type": "integer", "minimum": 0},
    "orphans_reparented": {"type": "integer", "minimum": 0},
    "total_events": {"type": "integer", "minimum": 0},
    "users_at_end": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0}
    },
    "zombies_at_end": {"type": "integer", "minimum": 0}
  }
}
