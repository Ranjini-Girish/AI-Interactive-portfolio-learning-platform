{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "events_input",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["seq", "tick", "kind"],
        "properties": {
          "seq":  {"type": "integer"},
          "tick": {"type": "integer"},
          "kind": {"type": "string"}
        }
      }
    }
  }
}
