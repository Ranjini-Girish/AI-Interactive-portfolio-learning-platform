{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "key_states",
  "type": "object",
  "required": ["keys"],
  "properties": {
    "keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "algorithm", "compromised_seq", "exhausted_seq",
          "installed_seq", "key_id", "last_use_tick", "max_uses",
          "retired_seq", "state", "uses_count"
        ],
        "properties": {
          "algorithm":      {"type": "string"},
          "compromised_seq":{"type": ["integer", "null"]},
          "exhausted_seq":  {"type": ["integer", "null"]},
          "installed_seq":  {"type": "integer"},
          "key_id":         {"type": "string"},
          "last_use_tick":  {"type": "integer"},
          "max_uses":       {"type": "integer"},
          "retired_seq":    {"type": ["integer", "null"]},
          "state":          {"type": "string", "enum": ["ACTIVE", "RETIRED", "EXHAUSTED", "COMPROMISED"]},
          "uses_count":     {"type": "integer"}
        }
      }
    }
  }
}
