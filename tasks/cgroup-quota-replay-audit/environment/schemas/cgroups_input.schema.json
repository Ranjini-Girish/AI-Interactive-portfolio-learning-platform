        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "parent_id": { "type": ["string", "null"] },
          "cpu_quota_ms": { "type": "integer", "minimum": 0 },
          "mem_quota_kb": { "type": "integer", "minimum": 0 },
          "io_quota_iops": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
