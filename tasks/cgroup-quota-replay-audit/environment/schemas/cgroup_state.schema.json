        "properties": {
          "cpu_quota_ms": { "type": "integer" },
          "cpu_used_ms": { "type": "integer" },
          "id": { "type": "string" },
          "io_quota_iops": { "type": "integer" },
          "io_used_iops": { "type": "integer" },
          "mem_quota_kb": { "type": "integer" },
          "mem_used_kb": { "type": "integer" },
          "parent_id": { "type": ["string", "null"] },
          "peak_cpu_ms": { "type": "integer" },
          "peak_mem_kb": { "type": "integer" },
