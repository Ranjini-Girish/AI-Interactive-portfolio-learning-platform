{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "lineage_graph",
  "type": "object",
  "required": ["cycles", "edges", "nodes"],
  "additionalProperties": false,
  "properties": {
    "cycles": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "string" } }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "in_degree", "out_degree"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "in_degree": { "type": "integer", "minimum": 0 },
          "out_degree": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
