{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "summary",
  "type": "object",
  "required": [
    "creates_rejected", "creates_succeeded", "deletes_succeeded",
    "final_cgroup_count", "final_task_count", "hot_cgroups",
    "moves_succeeded", "rejected_consumes", "throttled_consumes",
    "total_events", "total_violations"
  ],
  "additionalProperties": false,
  "properties": {
    "creates_rejected": { "type": "integer", "minimum": 0 },
    "creates_succeeded": { "type": "integer", "minimum": 0 },
    "deletes_succeeded": { "type": "integer", "minimum": 0 },
    "final_cgroup_count": { "type": "integer", "minimum": 0 },
    "final_task_count": { "type": "integer", "minimum": 0 },
    "hot_cgroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "violation_count"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "violation_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "moves_succeeded": { "type": "integer", "minimum": 0 },
    "rejected_consumes": { "type": "integer", "minimum": 0 },
    "throttled_consumes": { "type": "integer", "minimum": 0 },
    "total_events": { "type": "integer", "minimum": 0 },
    "total_violations": { "type": "integer", "minimum": 0 }
  }
}
