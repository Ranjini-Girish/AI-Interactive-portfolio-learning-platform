{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sas.json (initial Security Associations)",
  "type": "object",
  "additionalProperties": false,
  "required": ["sas"],
  "properties": {
    "sas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "top", "window_size", "owner"],
        "properties": {
          "id":          { "type": "string", "minLength": 1 },
          "top":         { "type": "integer", "minimum": 0 },
          "window_size": { "type": "integer", "minimum": 1 },
          "owner":       { "type": "string" }
        }
      }
    }
  }
}
