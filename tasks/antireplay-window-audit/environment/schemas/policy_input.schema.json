{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "policy.json (anti-replay policy axes)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "window_sizes_allowed",
    "on_replay",
    "on_too_old",
    "on_unknown_sa",
    "min_hot_threshold"
  ],
  "properties": {
    "window_sizes_allowed": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 1, "maximum": 4096 }
    },
    "on_replay":         { "type": "string", "enum": ["drop", "log_only"] },
    "on_too_old":        { "type": "string", "enum": ["drop", "log_only"] },
    "on_unknown_sa":     { "type": "string", "enum": ["drop", "create_passive"] },
    "min_hot_threshold": { "type": "integer", "minimum": 0 }
  }
}
