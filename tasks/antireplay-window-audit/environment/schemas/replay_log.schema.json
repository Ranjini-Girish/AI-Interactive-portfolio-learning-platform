{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "replay_log.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "diagnostic", "esp_seq", "sa_id", "seq"],
        "properties": {
          "decision": {
            "type": "string",
            "enum": [
              "replay_logged",
              "replay_dropped",
              "too_old_logged",
              "too_old_dropped",
              "unknown_drop"
            ]
          },
          "diagnostic": {
            "type": "string",
            "enum": ["W_REPLAY", "W_TOO_OLD", "E_UNKNOWN_SA"]
          },
          "esp_seq": { "type": "integer", "minimum": 1 },
          "sa_id":   { "type": "string" },
          "seq":     { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
