{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "event_log.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "key", "op", "seq"],
        "properties": {
          "code": {
            "enum": [
              "D_OK_ADD",
              "D_REJECTED_SATURATE",
              "D_OK_REMOVE",
              "D_CLAMPED_REMOVE",
              "D_REJECTED_NEGATIVE",
              "D_OK_QUERY",
              "D_OK_CLEAR",
              "D_OK_RESIZE",
              "D_OK_DUMP"
            ]
          },
          "key": { "type": ["string", "null"] },
          "op": {
            "enum": ["add", "remove", "query", "clear", "resize", "dump_stats"]
          },
          "seq": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
