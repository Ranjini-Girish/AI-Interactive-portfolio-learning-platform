{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "query_log.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["queries"],
  "properties": {
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actual", "key", "outcome", "predicted", "seq"],
        "properties": {
          "actual": { "type": "boolean" },
          "key": { "type": "string" },
          "outcome": { "enum": ["tp", "fp", "tn", "fn"] },
          "predicted": { "type": "boolean" },
          "seq": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
