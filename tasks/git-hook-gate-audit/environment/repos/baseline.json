{
  "hook_policy": [
    {
      "name": "quality-gate",
      "kind": "pre-commit",
      "required_for_tiers": ["gold", "silver", "bronze"],
      "required_checks": ["lint", "conflict_markers", "debug_statements", "file_size"]
    },
    {
      "name": "msg-format",
      "kind": "commit-msg",
      "required_for_tiers": ["gold", "silver"],
      "required_checks": ["conventional_format"]
    },
    {
      "name": "secrets-scan",
      "kind": "pre-push",
      "required_for_tiers": ["gold", "silver"],
      "required_checks": ["credential_scan", "license_check"]
    }
  ],
  "branch_protection": {
    "protected_branches": ["main", "release"],
    "required_hooks_per_branch": {
      "main": ["pre-commit", "commit-msg", "pre-push"],
      "release": ["pre-commit", "pre-push"]
    }
  },
  "commit_msg": {
    "max_length_per_tier": {
      "gold": 50,
      "silver": 72,
      "bronze": 100
    },
    "type_whitelist_per_tier": {
      "gold": ["feat", "fix"],
      "silver": ["feat", "fix", "docs", "refactor", "perf"],
      "bronze": ["feat", "fix", "docs", "refactor", "perf", "style", "test", "chore", "ci", "build", "revert"]
    },
    "require_issue_ref_per_tier": {
      "gold": true,
      "silver": true,
      "bronze": false
    },
    "issue_ref_pattern": "^[A-Z]+-[0-9]+$"
  }
}
