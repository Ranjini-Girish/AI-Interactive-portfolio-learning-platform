{
  "name": "auth-module",
  "version": "1.3.0",
  "base_size_bytes": 5200,
  "features": {
    "default": ["jwt"],
    "jwt": [],
    "oauth": ["jwt", "dep:oauth-client"],
    "session": []
  },
  "feature_conflicts": [],
  "feature_size_weights": {
    "jwt": 0.15,
    "oauth": 0.25,
    "session": 0.10
  },
  "build_priority": 4,
  "weak_features": {},
  "dependencies": [
    {"name": "core-lib", "optional": false, "default_features": true, "features": ["serde"]},
    {"name": "token-store", "optional": false, "default_features": true, "features": []},
    {"name": "crypto-utils", "optional": false, "default_features": true, "features": []},
    {"name": "oauth-client", "optional": true, "default_features": true, "features": []}
  ],
  "exports": ["AuthProvider", "verify_token"],
  "conditional_exports": {
    "oauth": ["OAuthFlow", "exchange_code"]
  }
}
