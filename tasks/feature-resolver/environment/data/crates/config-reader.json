{
  "name": "config-reader",
  "version": "1.1.0",
  "base_size_bytes": 2100,
  "features": {
    "default": ["json"],
    "json": ["dep:json-parser"],
    "toml": ["dep:toml-parser"],
    "env": []
  },
  "feature_conflicts": [],
  "feature_size_weights": {
    "json": 0.15,
    "toml": 0.15,
    "env": 0.05
  },
  "build_priority": 6,
  "weak_features": {},
  "dependencies": [
    {"name": "utils", "optional": false, "default_features": true, "features": []},
    {"name": "serde-core", "optional": false, "default_features": true, "features": []},
    {"name": "json-parser", "optional": true, "default_features": true, "features": []},
    {"name": "toml-parser", "optional": true, "default_features": true, "features": []}
  ],
  "exports": ["Config", "load_config"],
  "conditional_exports": {}
}
