{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "move_graph.json output",
  "type": "object",
  "additionalProperties": false,
  "required": ["cycles", "edges", "nodes"],
  "properties": {
    "cycles": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {"type": "string"},
        "minItems": 2
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": {"type": "string"},
          "to":   {"type": "string"}
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "in_degree", "out_degree"],
        "properties": {
          "id":         {"type": "string"},
          "in_degree":  {"type": "integer", "minimum": 0},
          "out_degree": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
