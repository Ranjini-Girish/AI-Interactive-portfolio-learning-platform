# ── Production environment reference ───────────────────────────
# Copy values into Render (API) and Vercel (Web) dashboards — never commit secrets.

# ── Render / API service ───────────────────────────────────────
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://user:pass@host:5432/career_simulator
JWT_SECRET=generate-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Comma-separated if you have preview + production frontends
CORS_ORIGIN=https://your-app.vercel.app,https://your-app-*.vercel.app

# ── Vercel / Web project ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://career-sim-api.onrender.com
NEXT_PUBLIC_APP_NAME=AI Career Transition Simulator
