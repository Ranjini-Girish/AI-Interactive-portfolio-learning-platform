# ── Production environment reference ───────────────────────────
# Copy values into Fly.io secrets and Vercel dashboard — never commit secrets.

# ── Fly.io / API service (fly secrets set ...) ─────────────────
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://...  # set by: fly postgres attach
JWT_SECRET=generate-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
CORS_ORIGIN=https://career-simulator-ranjinigirish.vercel.app,https://career-simulator-sandy.vercel.app
PUBLIC_API_URL=https://career-simulator-api.fly.dev
CLERK_SECRET_KEY=sk_live_...

# ── Vercel / Web project ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://career-simulator-api.fly.dev
NEXT_PUBLIC_APP_NAME=AI Career Transition Simulator
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
